{
  "name": "tiltcheck",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "start": "pnpm --filter @tiltcheck/web start",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "seed:casino-scores": "tsx scripts/seed-casino-scores.ts",
    "seed:casinos": "pnpm seed:casino-scores",
    "crawl:emails": "tsx scripts/email-crawler.ts",
    "test:e2e": "pnpm --filter @tiltcheck/web test:e2e"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "semver": ">=5.7.2"
    }
  },
  "devDependencies": {
    "@tiltcheck/db": "workspace:*",
    "@tiltcheck/trust": "workspace:*",
    "@types/imap": "^0.8.42",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "imap": "^0.8.19",
    "mailparser": "^3.7.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
