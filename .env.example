# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000
# Empty until Chrome Web Store listing is live; then set full detail URL
NEXT_PUBLIC_CHROME_WEB_STORE_URL=

# API (Hono)
PORT=3001
NODE_ENV=development
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
SESSION_SECRET=change-me-in-production-min-32-chars

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI_WEB=http://localhost:3001/auth/discord/callback
DISCORD_REDIRECT_URI_EXT=http://localhost:3001/auth/discord/callback

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Extension build (defaults to Railway production if unset)
# Local: EXTENSION_API_URL=http://localhost:3001 EXTENSION_WEB_URL=http://localhost:3000
EXTENSION_API_URL=https://tiltcheck-api-production.up.railway.app
EXTENSION_WEB_URL=https://tiltcheckmvp-production.up.railway.app
# Optional; defaults to NEXT_PUBLIC_CHROME_WEB_STORE_URL at build time
EXTENSION_CWS_URL=

# Discord bot (Phase 5)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
TILTCHECK_API_URL=http://localhost:3001
TILTCHECK_BOT_API_TOKEN=

# Bonuses read proxy (v1 production API until ingest on v2)
BONUSES_UPSTREAM_URL=https://api.tiltcheck.me/bonuses

# Email crawler (local machine — posts to API /rgaas/email-ingest)
CRAWLER_EMAIL=
CRAWLER_APP_PASSWORD=
CRAWLER_API_URL=http://localhost:3001
# Shared secret for POST /rgaas/email-ingest (Bearer or X-Email-Ingest-Key). Empty = open in dev.
EMAIL_INGEST_SECRET=
# Max raw_email body size in bytes (default 524288 = 512 KiB)
EMAIL_INGEST_MAX_BYTES=
EMAIL_BONUS_FEED_PATH=

# Playwright (optional overrides)
PLAYWRIGHT_WEB_URL=http://localhost:3000
PLAYWRIGHT_API_URL=http://localhost:3001
