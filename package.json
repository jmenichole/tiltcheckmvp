{
  "name": "tiltcheck",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "start": "pnpm --filter @tiltcheck/web start",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "seed:casino-scores": "tsx scripts/seed-casino-scores.ts",
    "seed:casinos": "pnpm seed:casino-scores",
    "test:e2e": "pnpm --filter @tiltcheck/web test:e2e"
  },
  "devDependencies": {
    "@tiltcheck/db": "workspace:*",
    "@tiltcheck/trust": "workspace:*",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
