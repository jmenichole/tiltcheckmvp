{
  "name": "@tiltcheck/trust",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node --input-type=module -e \"import fs from 'node:fs'; fs.copyFileSync('src/casinos.json','dist/casinos.json')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo ok"
  },
  "dependencies": {
    "@tiltcheck/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
